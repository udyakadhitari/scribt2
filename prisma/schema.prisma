generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique

  name      String?
  imageUrl  String?

  subjects  Subject[]
  journalEntries JournalEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subject {
  id        String   @id @default(cuid())

  title     String
  color     String?

  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])

  chapters  Chapter[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Chapter {
  id        String   @id @default(cuid())

  title     String
  order     Int

  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id])

  notes     Note[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subjectId])
}

model Note {
  id        String   @id @default(cuid())

  title     String

  content   Json?

  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], references: [id])

  chats     NoteChat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chapterId])
}

model NoteChat {
  id        String   @id @default(cuid())

  noteId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  role      ChatRole

  content   String   @db.Text

  createdAt DateTime @default(now())

  @@index([noteId])
}

enum ChatRole {
  USER
  ASSISTANT
}

model JournalEntry {
  id          String   @id @default(cuid())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String?

  content     Json

  mood        String?

  createdAt   DateTime @default(now())

  date        DateTime

  updatedAt   DateTime @updatedAt

  @@index([userId])
}